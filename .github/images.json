{
  "shared_paths": [
    ".github/workflows/build-images.yaml",
    ".github/images.json",
    "go.mod"
  ],
  "groups": {
    "op-conductor-ops": {
      "mode": "apko",
      "melange_config": "op-conductor-ops/melange.yaml",
      "apko_config_dir": "op-conductor-ops/apko",
      "melange_workdir": "op-conductor-ops",
      "services": ["op-conductor-ops"],
      "paths": ["op-conductor-ops/**"]
    }
  },
  "images": {
    "cci-stats": {
      "context": ".",
      "dockerfile": "cci-stats/Dockerfile",
      "paths": ["cci-stats/**"]
    },
    "op-acceptor": {
      "context": ".",
      "dockerfile": "op-acceptor/Dockerfile",
      "paths": ["op-acceptor/**"]
    },
    "op-conductor-mon": {
      "context": ".",
      "dockerfile": "op-conductor-mon/Dockerfile",
      "paths": ["op-conductor-mon/**"]
    },
    "op-signer": {
      "context": ".",
      "dockerfile": "op-signer/Dockerfile",
      "paths": ["op-signer/**"]
    },
    "op-txproxy": {
      "context": ".",
      "dockerfile": "op-txproxy/Dockerfile",
      "paths": ["op-txproxy/**"]
    },
    "op-ufm": {
      "context": ".",
      "dockerfile": "op-ufm/Dockerfile",
      "paths": ["op-ufm/**"]
    },
    "peer-mgmt-service": {
      "context": ".",
      "dockerfile": "peer-mgmt-service/Dockerfile",
      "paths": ["peer-mgmt-service/**"]
    },
    "proxyd": {
      "context": ".",
      "dockerfile": "proxyd/Dockerfile",
      "paths": ["proxyd/**"]
    },
    "replica-healthcheck": {
      "context": ".",
      "dockerfile": "replica-healthcheck/Dockerfile",
      "paths": ["replica-healthcheck/**"]
    }
  }
}
