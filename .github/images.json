{
  "shared_paths": [
    ".github/workflows/factory.yaml",
    ".github/images.json",
    ".ko.yaml",
    "go.mod",
    "go.sum"
  ],
  "images": {
    "cci-stats": {
      "mode": "ko",
      "ko_working_directory": "cci-stats",
      "ko_importpath": "./cmd/runner",
      "env": "VERSION=v0.0.0",
      "paths": ["cci-stats/**"]
    },
    "op-acceptor": {
      "context": ".",
      "dockerfile": "op-acceptor/Dockerfile",
      "paths": ["op-acceptor/**"]
    },
    "op-conductor-mon": {
      "mode": "ko",
      "ko_working_directory": "op-conductor-mon",
      "ko_importpath": "./cmd/monitor",
      "env": "VERSION=v0.0.0",
      "paths": ["op-conductor-mon/**"]
    },
    "op-conductor-ops": {
      "context": ".",
      "dockerfile": "op-conductor-ops/Dockerfile",
      "paths": ["op-conductor-ops/**"]
    },
    "op-signer": {
      "mode": "ko",
      "ko_working_directory": "op-signer",
      "ko_importpath": "./cmd",
      "env": "VERSION=v0.0.0",
      "paths": ["op-signer/**"]
    },
    "op-txproxy": {
      "mode": "ko",
      "ko_working_directory": "op-txproxy",
      "ko_importpath": "./cmd",
      "env": "VERSION=v0.0.0",
      "paths": ["op-txproxy/**"]
    },
    "op-ufm": {
      "mode": "ko",
      "ko_working_directory": "op-ufm",
      "ko_importpath": "./cmd/ufm",
      "env": "VERSION=v0.0.0",
      "paths": ["op-ufm/**"]
    },
    "peer-mgmt-service": {
      "mode": "ko",
      "ko_working_directory": "peer-mgmt-service",
      "ko_importpath": "./cmd/pms",
      "env": "VERSION=v0.0.0",
      "paths": ["peer-mgmt-service/**"]
    },
    "proxyd": {
      "mode": "ko",
      "ko_working_directory": "proxyd",
      "ko_importpath": "./cmd/proxyd",
      "env": "VERSION=v0.0.0",
      "paths": ["proxyd/**"]
    },
    "replica-healthcheck": {
      "context": ".",
      "dockerfile": "replica-healthcheck/Dockerfile",
      "paths": ["replica-healthcheck/**"]
    }
  }
}
